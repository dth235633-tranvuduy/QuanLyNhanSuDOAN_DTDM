  <script>
    const menuGroups = Array.from(document.querySelectorAll("[data-menu-group]"));
    const currentPath = window.location.pathname.replace(/\/$/, "") || "/";

    function normalizePath(path) {
      return (path || "").replace(/\/$/, "") || "/";
    }

    document.querySelectorAll(".sidebar nav a[href]").forEach((link) => {
      const hrefPath = normalizePath(new URL(link.href, window.location.origin).pathname);
      if (hrefPath === currentPath) {
        link.classList.add("is-active");
        const parentGroup = link.closest("[data-menu-group]");
        if (parentGroup) {
          parentGroup.classList.add("has-active");
        }
      }
    });

    menuGroups.forEach((group) => {
      const toggle = group.querySelector(".menu-group-toggle");

      toggle.addEventListener("click", () => {
        const willOpen = group.classList.contains("is-collapsed");

        menuGroups.forEach((otherGroup) => {
          const otherToggle = otherGroup.querySelector(".menu-group-toggle");
          otherGroup.classList.add("is-collapsed");
          otherToggle.setAttribute("aria-expanded", "false");
        });

        if (willOpen) {
          group.classList.remove("is-collapsed");
          toggle.setAttribute("aria-expanded", "true");
        }
      });

      if (!group.classList.contains("is-collapsed")) {
        toggle.setAttribute("aria-expanded", "true");
      }
    });

    document.querySelectorAll(".menu-items a, .menu-items button").forEach((menuAction) => {
      menuAction.addEventListener("click", () => {
        menuGroups.forEach((group) => {
          const groupToggle = group.querySelector(".menu-group-toggle");
          group.classList.add("is-collapsed");
          if (groupToggle) {
            groupToggle.setAttribute("aria-expanded", "false");
          }
        });
      });
    });
  </script>
