<%- include("partials/layoutStart", { title, entities, entityName }) %>

<section class="page-header row">
  <div>
    <h1>Chỉnh Hệ Số Lương</h1>
    <p>Cập nhật hệ số lương theo hợp đồng đang áp dụng cho từng nhân viên.</p>
  </div>
</section>

<div class="table-wrap data-grid-card salary-coefficient-panel">
  <h2 class="section-title">Tìm nhân viên</h2>
  <form class="attendance-filter" method="get" action="/admin/he-so-luong">
    <label>
      <span>Mã/Tên nhân viên</span>
      <input type="text" name="keyword" value="<%= keyword || '' %>" placeholder="VD: NV001 hoặc Trần Văn A" />
    </label>
    <div class="filter-actions">
      <button class="btn small" type="submit">Lọc dữ liệu</button>
      <a class="btn ghost small" href="/admin/he-so-luong">Xóa lọc</a>
    </div>
  </form>

  <% if (flash && flash.message) { %>
    <p class="news-flash <%= flash.isSuccess ? 'success' : 'error' %>"><%= flash.message %></p>
  <% } %>
</div>

<div class="table-wrap data-grid-card">
  <h2 class="section-title">Danh sách hệ số lương hiện tại</h2>
  <table class="admin-data-table salary-coefficient-table">
    <thead>
      <tr>
        <th>Mã nhân viên</th>
        <th>Họ tên</th>
        <th>Mã hợp đồng</th>
        <th>Loại hợp đồng</th>
        <th>Trạng thái</th>
        <th>Mức lương</th>
        <th>Hệ số lương</th>
        <th>Lương áp dụng</th>
        <th>Cập nhật</th>
      </tr>
    </thead>
    <tbody>
      <% if (!rows || !rows.length) { %>
        <tr>
          <td colspan="9">Không có dữ liệu nhân viên phù hợp.</td>
        </tr>
      <% } %>

      <% (rows || []).forEach((row) => { %>
        <tr>
          <td><%= row.MaNhanVien || '--' %></td>
          <td><%= row.HoTen || '--' %></td>
          <td><%= row.MaHopDong || '--' %></td>
          <td><%= row.LoaiHopDong || '--' %></td>
          <td><%= row.TrangThai_HopDong || '--' %></td>
          <td><%= formatNumberComma(row.MucLuong || 0) %></td>
          <td><strong><%= Number(row.HeSoLuong || 1).toFixed(2) %></strong></td>
          <td><strong><%= formatNumberComma(row.LuongApDung || 0) %></strong></td>
          <td>
            <% if (row.hasContract) { %>
              <form class="salary-coefficient-form" method="post" action="/admin/he-so-luong/<%= row.MaHopDong %>">
                <input type="hidden" name="keyword" value="<%= keyword || '' %>" />
                <input
                  class="coefficient-input"
                  type="number"
                  name="heSoLuong"
                  min="0.1"
                  max="20"
                  step="0.01"
                  value="<%= Number(row.HeSoLuong || 1).toFixed(2) %>"
                  required
                />
                <button class="btn small" type="submit">Lưu</button>
              </form>
            <% } else { %>
              <span class="status-pill">Chưa có hợp đồng</span>
            <% } %>
          </td>
        </tr>
      <% }); %>
    </tbody>
  </table>
</div>

<%- include("partials/layoutEnd") %>
