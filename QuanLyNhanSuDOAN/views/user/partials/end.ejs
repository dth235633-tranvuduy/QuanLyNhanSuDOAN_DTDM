  <script>
    (function () {
      const topbar = document.querySelector(".user-topbar");
      const toggleBtn = document.querySelector(".menu-toggle");
      const nav = document.querySelector("#userMainNav");

      if (!topbar || !toggleBtn || !nav) {
        return;
      }

      function closeMenu() {
        topbar.classList.remove("menu-open");
        toggleBtn.setAttribute("aria-expanded", "false");
      }

      toggleBtn.addEventListener("click", function () {
        const willOpen = !topbar.classList.contains("menu-open");
        topbar.classList.toggle("menu-open", willOpen);
        toggleBtn.setAttribute("aria-expanded", willOpen ? "true" : "false");
      });

      nav.querySelectorAll("a").forEach(function (link) {
        link.addEventListener("click", function () {
          if (window.innerWidth <= 1280) {
            closeMenu();
          }
        });
      });

      window.addEventListener("resize", function () {
        if (window.innerWidth > 1280) {
          closeMenu();
        }
      });
    })();
  </script>
