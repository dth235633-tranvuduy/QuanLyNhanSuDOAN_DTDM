<%- include('partials/start', { title, activeMenu, employee }) %>

<link
  rel="stylesheet"
  href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css"
  integrity="sha256-p4NxAoJBhIIN+hmNHrzRCf9tD/miZyoHS5obTRR9BMY="
  crossorigin=""
/>

<% if (!employee) { %>
  <section class="hero empty">
    <h1>Không tìm thấy dữ liệu nhân viên</h1>
    <p>Vui lòng liên hệ quản trị để cập nhật hồ sơ trước khi chấm công.</p>
  </section>
<% } else { %>
  <section class="attendance-board" id="cham-cong">
    <section class="attendance-station">
      <header class="attendance-station-head">
        <div>
          <h3><i class="bi bi-fingerprint"></i> TRẠM CHẤM CÔNG</h3>
          <p><%= stationInfo.longDateLabel %></p>
        </div>
        <div class="attendance-station-clock" data-live-clock><%= stationInfo.currentTime %></div>
      </header>

      <div class="attendance-station-body">
        <div class="attendance-station-form">
          <label>
            <span><i class="bi bi-briefcase-fill"></i> Ca làm việc</span>
            <input type="text" value="Ca hành chính (08:00 - 17:00)" readonly />
          </label>

          <label>
            <span><i class="bi bi-clock-history"></i> Giờ vào dự kiến</span>
            <input type="text" value="<%= stationInfo.expectedCheckIn %>" readonly />
          </label>

          <label>
            <span><i class="bi bi-calendar-event"></i> Kỳ chấm công</span>
            <input
              type="text"
              value="<%= stationInfo.periodLabel %> - <%= stationInfo.periodStatus %>"
              readonly
            />
          </label>

          <label>
            <span><i class="bi bi-geo-alt-fill"></i> Khoảng cách đến công ty</span>
            <input
              type="text"
              value="<%= todayAttendance?.checkInDistanceText || 'Không xác định' %>"
              readonly
              data-distance-input
            />
          </label>
          <p class="attendance-check-rule">
            Chỉ cho phép check-in khi cách trụ sở chính tối đa
            <strong><%= stationInfo.maxDistanceMeters %>m</strong>.
          </p>

          <label>
            <span><i class="bi bi-pin-map-fill"></i> Vị trí check-in</span>
            <input
              type="text"
              value="<%= todayAttendance?.checkInAddress || 'Chưa có vị trí' %>"
              readonly
              data-address-input
            />
          </label>

          <label>
            <span><i class="bi bi-clock-fill"></i> Thời điểm check-in</span>
            <input type="text" value="<%= todayAttendance?.checkInTimeText || '--:--' %>" readonly />
          </label>

          <div class="attendance-check-actions">
            <button type="button" class="attendance-checkin-btn" data-locate-btn>
              <i class="bi bi-crosshair"></i> LẤY VỊ TRÍ HIỆN TẠI
            </button>
            <form method="post" action="/user/cham-cong/xac-nhan">
              <input type="hidden" name="latitude" value="<%= todayAttendance?.latitude ?? '' %>" data-lat-input />
              <input type="hidden" name="longitude" value="<%= todayAttendance?.longitude ?? '' %>" data-lng-input />
              <input type="hidden" name="address" value="<%= todayAttendance?.checkInAddress || '' %>" data-hidden-address-input />
              <button
                type="submit"
                class="attendance-checkin-btn"
                data-checkin-submit
                <%= stationInfo.canCheckIn && stationInfo.periodIsOpen ? '' : 'disabled title="Ngoai khung gio hoac ky cham cong dang khoa"' %>
              >
                <i class="bi bi-play-circle-fill"></i> BẮT ĐẦU CA (CHECK-IN)
              </button>
            </form>
            <span class="attendance-today-status <%= todayAttendance ? todayAttendance.className : 'unknown' %>">
              Hôm nay: <strong><%= todayAttendance ? todayAttendance.label : 'Chưa chấm công' %></strong>
            </span>
          </div>

          <p class="attendance-check-note" data-locate-status>
            Mẹo: Nếu trình duyệt chặn GPS, bạn có thể bấm trực tiếp lên bản đồ để chọn vị trí check-in.
          </p>

          <% if (!stationInfo.canCheckIn) { %>
            <p class="attendance-check-notice">Hiện ngoài khung giờ chấm công. Chỉ chấm công từ 08:00 đến 17:00.</p>
          <% } %>

          <% if (!stationInfo.periodIsOpen) { %>
            <p class="attendance-check-notice">Kỳ chấm công <%= stationInfo.periodLabel %> đang khóa, vui lòng liên hệ quản trị viên.</p>
          <% } %>

          <% if (checkInNotice) { %>
            <p class="attendance-check-notice"><%= checkInNotice %></p>
          <% } %>
        </div>

        <div class="attendance-station-map">
          <h4><i class="bi bi-pin-map-fill"></i> Xác nhận vị trí của bạn</h4>
          <div id="attendanceMap" class="attendance-map-canvas"></div>
        </div>
      </div>
    </section>

    <footer class="attendance-footer">
      <a href="/user/cham-cong" class="attendance-back"><i class="bi bi-table"></i> Xem bảng chấm công</a>
    </footer>
  </section>
<% } %>

<script
  src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"
  integrity="sha256-20nQCchB9co0qIjJZRGuk2/Z9VM+kNiyxNV1lvTlZBo="
  crossorigin=""
></script>

<script>
  (function () {
    const clock = document.querySelector('[data-live-clock]');
    if (!clock) return;

    function tick() {
      const now = new Date();
      clock.textContent = now.toLocaleTimeString('vi-VN', { hour12: false });
    }

    tick();
    setInterval(tick, 1000);
  })();

  (function () {
    const mapContainer = document.getElementById('attendanceMap');
    if (!mapContainer || typeof L === 'undefined') return;

    const office = {
      lat: Number('<%= stationInfo.office.lat %>'),
      lng: Number('<%= stationInfo.office.lng %>'),
      label: '<%= stationInfo.office.label %>'
    };

    const latInput = document.querySelector('[data-lat-input]');
    const lngInput = document.querySelector('[data-lng-input]');
    const addressInput = document.querySelector('[data-address-input]');
    const hiddenAddressInput = document.querySelector('[data-hidden-address-input]');
    const distanceInput = document.querySelector('[data-distance-input]');
    const locateButton = document.querySelector('[data-locate-btn]');
    const locateStatus = document.querySelector('[data-locate-status]');
    const checkInForm = document.querySelector('form[action="/user/cham-cong/xac-nhan"]');
    const checkInSubmitButton = document.querySelector('[data-checkin-submit]');
    const maxDistanceMeters = Number('<%= stationInfo.maxDistanceMeters %>');
    const canCheckInByPolicy = <%= stationInfo.canCheckIn && stationInfo.periodIsOpen ? 'true' : 'false' %>;

    const map = L.map('attendanceMap').setView([office.lat, office.lng], 16);
    L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
      attribution: '&copy; OpenStreetMap contributors'
    }).addTo(map);

    L.marker([office.lat, office.lng]).addTo(map).bindPopup(office.label).openPopup();
    let userMarker = null;

    function setLocateStatus(text, level) {
      if (!locateStatus) return;
      locateStatus.textContent = text;
      locateStatus.style.color = level === 'error' ? '#b03e3e' : '#2c5b7d';
    }

    function toRadians(value) {
      return (value * Math.PI) / 180;
    }

    function distanceMeters(fromLat, fromLng, toLat, toLng) {
      const earthRadius = 6371000;
      const dLat = toRadians(toLat - fromLat);
      const dLng = toRadians(toLng - fromLng);
      const a =
        Math.sin(dLat / 2) * Math.sin(dLat / 2) +
        Math.cos(toRadians(fromLat)) *
          Math.cos(toRadians(toLat)) *
          Math.sin(dLng / 2) *
          Math.sin(dLng / 2);
      const c = 2 * Math.atan2(Math.sqrt(a), Math.sqrt(1 - a));
      return Math.round(earthRadius * c);
    }

    async function reverseGeocode(lat, lng) {
      try {
        const response = await fetch(
          `https://nominatim.openstreetmap.org/reverse?format=jsonv2&lat=${lat}&lon=${lng}`,
          {
            headers: { Accept: 'application/json' }
          }
        );
        const payload = await response.json();
        return payload.display_name || `Lat ${lat.toFixed(6)}, Lng ${lng.toFixed(6)}`;
      } catch (error) {
        return `Lat ${lat.toFixed(6)}, Lng ${lng.toFixed(6)}`;
      }
    }

    async function updateLocation(lat, lng) {
      if (userMarker) {
        userMarker.setLatLng([lat, lng]);
      } else {
        userMarker = L.marker([lat, lng]).addTo(map).bindPopup('Vị trí của bạn');
      }

      map.setView([lat, lng], 17);

      const meters = distanceMeters(lat, lng, office.lat, office.lng);
      if (distanceInput) {
        distanceInput.value = `${new Intl.NumberFormat('vi-VN').format(meters)} m`;
      }

      if (checkInSubmitButton && Number.isFinite(maxDistanceMeters) && canCheckInByPolicy) {
        if (meters > maxDistanceMeters) {
          checkInSubmitButton.disabled = true;
          checkInSubmitButton.title = `Can o trong pham vi ${maxDistanceMeters}m de check-in`;
        } else {
          checkInSubmitButton.disabled = false;
          checkInSubmitButton.removeAttribute('title');
        }
      }

      const addressText = await reverseGeocode(lat, lng);
      if (addressInput) {
        addressInput.value = addressText;
      }
      if (hiddenAddressInput) {
        hiddenAddressInput.value = addressText;
      }

      if (latInput) latInput.value = lat.toFixed(7);
      if (lngInput) lngInput.value = lng.toFixed(7);

      setLocateStatus('Đã cập nhật vị trí check-in.', 'ok');
    }

    function requestCurrentLocation() {
      const hostname = window.location.hostname || '';
      const isLocalHost =
        hostname === 'localhost' ||
        hostname === '127.0.0.1' ||
        hostname === '::1';

      if (!window.isSecureContext && !isLocalHost) {
        setLocateStatus(
          'Trinh duyet chi cho phep lay GPS tren HTTPS hoac localhost. Hay mo bang localhost hoac bat HTTPS.',
          'error'
        );
        return;
      }

      if (!navigator.geolocation) {
        setLocateStatus('Trình duyệt không hỗ trợ GPS. Hãy bấm lên bản đồ để chọn vị trí.', 'error');
        return;
      }

      setLocateStatus('Đang lấy vị trí hiện tại...', 'ok');

      navigator.geolocation.getCurrentPosition(
        (position) => {
          updateLocation(position.coords.latitude, position.coords.longitude);
        },
        (error) => {
          if (error && error.code === error.PERMISSION_DENIED) {
            setLocateStatus(
              'Ban da chan quyen vi tri. Hay bam vao bieu tuong khoa/cai dat canh thanh dia chi de cho phep vi tri.',
              'error'
            );
            return;
          }

          if (error && error.code === error.POSITION_UNAVAILABLE) {
            setLocateStatus(
              'Khong xac dinh duoc GPS hien tai (tin hieu yeu). Thu di ra ngoai troi hoac bam chon vi tri tren ban do.',
              'error'
            );
            return;
          }

          if (error && error.code === error.TIMEOUT) {
            setLocateStatus(
              'Het thoi gian lay GPS. Thu bam lai Lay vi tri hien tai hoac chon vi tri tren ban do.',
              'error'
            );
            return;
          }

          setLocateStatus('Không lấy được GPS. Hãy cấp quyền vị trí hoặc bấm lên bản đồ để chọn thủ công.', 'error');
        },
        {
          enableHighAccuracy: true,
          timeout: 15000,
          maximumAge: 0
        }
      );
    }

    const existingLat = Number.parseFloat(latInput?.value || '');
    const existingLng = Number.parseFloat(lngInput?.value || '');
    if (Number.isFinite(existingLat) && Number.isFinite(existingLng)) {
      updateLocation(existingLat, existingLng);
      setLocateStatus('Đang dùng vị trí check-in đã lưu gần nhất.', 'ok');
    }

    if (locateButton) {
      locateButton.addEventListener('click', requestCurrentLocation);
    }

    map.on('click', (event) => {
      updateLocation(event.latlng.lat, event.latlng.lng);
      setLocateStatus('Đã chọn vị trí thủ công trên bản đồ.', 'ok');
    });

    if (checkInForm) {
      checkInForm.addEventListener('submit', (event) => {
        const lat = Number.parseFloat(latInput?.value || '');
        const lng = Number.parseFloat(lngInput?.value || '');
        if (!Number.isFinite(lat) || !Number.isFinite(lng)) {
          event.preventDefault();
          setLocateStatus('Vui lòng lấy vị trí hiện tại hoặc bấm lên bản đồ trước khi check-in.', 'error');
          return;
        }

        const meters = distanceMeters(lat, lng, office.lat, office.lng);
        if (Number.isFinite(maxDistanceMeters) && meters > maxDistanceMeters) {
          event.preventDefault();
          setLocateStatus(
            `Ban can den gan tru so hon. Khoang cach hien tai ${new Intl.NumberFormat('vi-VN').format(meters)}m, gioi han ${maxDistanceMeters}m.`,
            'error'
          );
        }
      });
    }

    requestCurrentLocation();
  })();
</script>

<%- include('partials/end') %>
