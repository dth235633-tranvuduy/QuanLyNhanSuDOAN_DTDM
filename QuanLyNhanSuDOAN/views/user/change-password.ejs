<%- include('partials/start', { title, activeMenu, employee }) %>

<section class="profile-neo password-change-page">
  <header class="profile-neo-head password-change-head">
    <div class="profile-neo-identity">
      <h1>Đổi mật khẩu</h1>
      <p><i class="bi bi-shield-lock-fill"></i> Cập nhật mật khẩu đăng nhập tài khoản của bạn</p>
    </div>
  </header>

  <% if (flash?.message) { %>
    <div class="password-flash <%= flash.isSuccess ? 'success' : 'error' %>">
      <i class="bi <%= flash.isSuccess ? 'bi-check-circle-fill' : 'bi-exclamation-triangle-fill' %>"></i>
      <span><%= flash.message %></span>
    </div>
  <% } %>

  <form class="password-change-form" method="post" action="/user/doi-mat-khau" autocomplete="off">
    <div class="password-form-grid">
      <label>
        <span>Mật khẩu hiện tại</span>
        <input type="password" name="matKhauCu" required />
      </label>

      <label>
        <span>Mật khẩu mới</span>
        <input type="password" name="matKhauMoi" required />
      </label>

      <label>
        <span>Xác nhận mật khẩu mới</span>
        <input type="password" name="xacNhanMatKhauMoi" required />
      </label>
    </div>

    <div class="password-form-actions">
      <button class="profile-neo-btn primary" type="submit">
        <i class="bi bi-key-fill"></i>
        Cập nhật mật khẩu
      </button>
      <a href="/user" class="profile-neo-btn secondary">
        <i class="bi bi-arrow-left"></i>
        Về trang chủ
      </a>
    </div>
  </form>
</section>

<%- include('partials/end') %>
