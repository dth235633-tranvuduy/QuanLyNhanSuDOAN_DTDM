<%- include("partials/layoutStart", { title, entities }) %>

<section class="page-header">
  <h1>Đổi mật khẩu hệ thống</h1>
  <p>Bảo mật tài khoản quản trị bằng việc cập nhật mật khẩu định kỳ.</p>
</section>

<div class="form-wrap">
  <% if (flash?.message) { %>
    <div class="news-flash <%= flash.isSuccess ? 'success' : 'error' %>">
      <%= flash.message %>
    </div>
  <% } %>

  <form method="post" action="/admin/doimatkhau" autocomplete="off">
    <div class="grid">
      <label>
        <span>Mật khẩu hiện tại</span>
        <input
          type="password"
          name="matKhauCu"
          placeholder="Nhập mật khẩu hiện tại"
          required
        />
      </label>
      <label>
        <span>Mật khẩu mới</span>
        <input
          type="password"
          name="matKhauMoi"
          placeholder="Nhập mật khẩu mới"
          required
        />
      </label>
      <label>
        <span>Nhập lại mật khẩu mới</span>
        <input
          type="password"
          name="xacNhanMatKhauMoi"
          placeholder="Nhập lại mật khẩu mới"
          required
        />
      </label>
    </div>
    <button class="btn" type="submit">Cập nhật mật khẩu</button>
  </form>
</div>

<%- include("partials/layoutEnd") %>
